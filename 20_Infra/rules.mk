# Si quieres usar luces RGB
RGBLIGHT_ENABLE = yes

# Si tu Corne tiene pantallas OLED
OLED_ENABLE = yes

# Si quieres usar Encoder (si tu versión de PCB lo soporta)
ENCODER_ENABLE = no

# Para ahorrar memoria si te quedas sin espacio
LTO_ENABLE = yes

TAP_DANCE_ENABLE = yes
NKRO_ENABLE = no
MOUSEKEY_ENABLE = no    # Si no usas el teclado para mover el ratón
COMMAND_ENABLE = no     # Desactiva comandos internos de QMK
CONSOLE_ENABLE = no     # Desactiva la consola de depuración
EXTRAKEY_ENABLE = yes   # Mantén esto para el volumen, pero si falla, prueba 'no'
